# Local secrets for `wrangler`/`vite dev`. Copy to `.dev.vars` (gitignored) and
# fill in. In production these are Cloudflare Pages secrets / CI secrets — never
# committed. PUBLIC_* are build-time public vars (safe to expose to the client).

# — Cloudflare Turnstile (anti-spam) —
PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET_KEY=

# — Cloudflare Web Analytics (public beacon token) —
PUBLIC_CF_ANALYTICS_TOKEN=

# — Lead-form email (Cloudflare Email Routing `send_email` binding) —
# The binding itself (SEB) is configured in wrangler.jsonc, not here, and only
# works under `wrangler dev` with Email Routing set up. Under plain `vite dev`
# the form validates and logs but does not send. These two are plain addresses:
EMAIL_FROM=hello@stephenredding.com
EMAIL_TO=
